# Example environment variables for GourmetCanvas
# Copy this to "backend/.env" and fill in your own values for local development.
# (Django loads the .env located next to manage.py, i.e. backend/.env)

# Django settings
SECRET_KEY=your-secret-key-here   # REQUIRED when DEBUG=False
DEBUG=True            # set to False in production
ALLOWED_HOSTS=localhost,127.0.0.1

# Allowed CORS origins (comma-separated). Must include the frontend origin(s).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (leave blank to use sqlite locally)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# HotPepper API key
HOTPEPPER_API_KEY=your-hotpepper-key

# Gemini API key
GEMINI_API_KEY=your-gemini-key

# Google Maps API key
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Optional: Other API keys or settings can go here
